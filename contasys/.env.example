# ──────────────────────────────────────────────
# REQUIRED - Pon estos valores en Vercel
# Saca los reales de tu .env.local
# ──────────────────────────────────────────────

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=https://smzedpuetwqqcelhyfpe.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=pon-tu-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=pon-tu-service-role-key-aqui

# Database (Prisma) — obligatorio el ?schema=contasys
DATABASE_URL=postgresql://postgres:password@db.tu-proyecto.supabase.co:5432/postgres?schema=contasys

# App URL
NEXT_PUBLIC_APP_URL=https://tu-dominio.vercel.app

# ──────────────────────────────────────────────
# OPCIONAL
# ──────────────────────────────────────────────

# PayPal (suscripciones)
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
# PAYPAL_CLIENT_SECRET=your-paypal-secret

# SRI - firma electrónica .p12
# CLAVE_FIRMA_SRI=your-signature-key

# SRI - override ambiente (pruebas/produccion)
# SRI_AMBIENTE=pruebas

# Cron - secreto para /api/cron/recurrencias
# CRON_SECRET=your-cron-secret
