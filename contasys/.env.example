# ============================================================
# REQUIRED - Pon estos valores en tu Vercel Dashboard
# Los valores reales estan en .env.local (gitignored)
# ============================================================

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=https://smzedpuetwqqcelhyfpe.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=pon-tu-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=pon-tu-service-role-key-aqui

# Database (Prisma) - obligatorio el ?schema=contasys al final
DATABASE_URL=postgresql://postgres:password@db.tu-proyecto.supabase.co:5432/postgres?schema=contasys

# App URL
NEXT_PUBLIC_APP_URL=https://contasys-ec.vercel.app

# ============================================================
# OPCIONAL - solo si usas el feature correspondiente
# ============================================================

# PayPal (suscripciones)
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
# PAYPAL_CLIENT_SECRET=your-paypal-secret
# PAYPAL_WEBHOOK_ID=el-id-del-webhook-en-paypal-dashboard

# SRI - firma electronica (contrasena del .p12)
# CLAVE_FIRMA_SRI=your-p12-password
# P12_BASE64=base64-del-archivo-p12-completo

# SRI - override ambiente (pruebas/produccion)
# SRI_AMBIENTE=pruebas

# Encriptacion - clave maestra para cifrar datos sensibles en BD
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# APP_ENCRYPTION_KEY=your-256-bit-hex-key

# Cron - secreto para /api/cron/recurrencias y /api/cron/recordatorios-cobro
# CRON_SECRET=your-cron-secret
